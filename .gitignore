# ============================================================================
# VP-Planilla Repository — .gitignore
# Organized per stack: Backend (Node/TypeScript), Frontend (Next.js), Java
# utility, General (OS/IDE/temp). Generated files are never tracked.
# ============================================================================

# ===== BACKEND (Node.js / TypeScript) =====
# Compiled TypeScript output — regenerate with: cd src/backend && npm run build
src/backend/dist/
src/backend/*.tsbuildinfo

# Dependencies
src/backend/node_modules/

# Package manager lock files (tracked in apps for deterministic builds)
# **/package-lock.json (removed general ignore)
!src/backend/package-lock.json
!src/frontend/package-lock.json

# ===== FRONTEND (Next.js) =====
# Next.js build output — regenerate with: cd src/frontend && npm run build
src/frontend/.next/
src/frontend/out/

# Dependencies
src/frontend/node_modules/

# ===== JAVA UTILITY (Maven) =====
# Maven build output — regenerate with: mvn clean package -f src/Java/clocklogs/pom.xml
src/Java/clocklogs/target/

# Compiled classes and archives
src/Java/clocklogs/*.class
src/Java/clocklogs/*.jar

# Maven metadata
src/Java/clocklogs/pom.xml.tag
src/Java/clocklogs/pom.xml.releaseBackup
src/Java/clocklogs/pom.xml.versionsBackup
src/Java/clocklogs/pom.xml.next
src/Java/clocklogs/release.properties
src/Java/clocklogs/dependency-reduced-pom.xml

# ===== GENERAL (IDE, OS, Temp Files) =====
# IDE configurations
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Python artifacts
**/__pycache__/
*.py[cod]
*$py.class

# Log files
*.log
logs/

# LaTeX auxiliary files
*.aux
*.bbl
*.blg
*.lof
*.lot
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.synctex(busy)
*.txt
/docs/Formal/TFM.pdf
/docs/Formal/out/

# Test coverage reports — generated, do not commit
coverage/
*.lcov

# Temp/debug scripts — do not commit
parse_tmp.js
temp_script.py
test_hours.js
check_employee.ts
query_emp.mjs
*.tmp.js
*.tmp.ts

# ===== TRACKED CONFIGURATION DIRECTORIES =====
# .claude/ directory is tracked (project configuration)
!.claude/
!.claude/**

# Except local/personal settings
.claude/settings.local.json
.claude/worktrees/

# .planning/ directory is tracked (milestone & phase planning)
!.planning/
!.planning/**

# Graphify — build cache and large generated artifacts
graphify-out/
.planning/graphs/graph.json
.planning/graphs/graph.html
.planning/graphs/.last-build-snapshot.json

# Auto-generated file inventories (do not commit)
tracked_files.txt

# Frontend TypeScript build cache
src/frontend/tsconfig.tsbuildinfo
