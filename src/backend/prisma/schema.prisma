generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model vpg_audit_logs {
  id        Int       @id @default(autoincrement())
  user_id   Int
  action    String    @db.VarChar(100)
  entity    String    @db.VarChar(100)
  entity_id Int
  timestamp DateTime  @db.Timestamp(6)
  details   String?
  vpg_users vpg_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vpg_audit_logs_users_14")

  @@index([user_id], map: "idx_vpg_audit_logs_user_id")
}

model vpg_bonuses {
  id            Int           @id @default(autoincrement())
  employee_id   Int
  description   String        @db.VarChar(255)
  amount        Decimal       @db.Decimal(10, 2)
  granted_at    DateTime      @db.Date
  vpg_employees vpg_employees @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vpg_bonuses_employees_15")

  @@index([employee_id], map: "idx_vpg_bonuses_employee_id")
}

model vpg_branch_employee {
  branch_id     Int
  employee_id   Int
  vpg_branches  vpg_branches  @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_branch_employee_branches_03")
  vpg_employees vpg_employees @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_branch_employee_employees_04")

  @@id([branch_id, employee_id])
  @@index([branch_id], map: "idx_vpg_branch_employee_branch_id")
  @@index([employee_id], map: "idx_vpg_branch_employee_employee_id")
}

model vpg_branches {
  id                    Int                     @id @default(autoincrement())
  branch_name           String                  @db.VarChar(50)
  location              String                  @db.VarChar(100)
  version               Int                     @default(1)
  vpg_branch_employee   vpg_branch_employee[]
  vpg_enterprise_branch vpg_enterprise_branch[]
}

model vpg_clock_logs {
  id            Int           @id @default(autoincrement())
  employee_id   Int
  timestamp     DateTime      @db.Timestamp(6)
  log_type      String        @db.VarChar(10)
  remarks       String?
  version       Int           @default(1)
  vpg_employees vpg_employees @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vpg_clock_logs_employees_11")

  @@index([employee_id], map: "idx_vpg_clock_logs_employee_id")
}

model vpg_deductions {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @db.VarChar(100)
  description            String
  percentage             Decimal?                 @db.Decimal(5, 2)
  fixed_amount           Decimal?                 @db.Decimal(10, 2)
  version                Int                      @default(1)
  vpg_employee_deduction vpg_employee_deduction[]
}

model vpg_employee_deduction {
  employee_id    Int
  deduction_id   Int
  vpg_deductions vpg_deductions @relation(fields: [deduction_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_employee_deduction_deductions_10")
  vpg_employees  vpg_employees  @relation(fields: [employee_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_employee_deduction_employees_09")

  @@id([employee_id, deduction_id])
  @@index([deduction_id], map: "idx_vpg_employee_deduction_deduction_id")
  @@index([employee_id], map: "idx_vpg_employee_deduction_employee_id")
}

model vpg_employee_documents {
  id            Int           @id @default(autoincrement())
  employee_id   Int
  file_path     String        @db.VarChar(255)
  document_type String        @db.VarChar(50)
  uploaded_at   DateTime      @db.Timestamp(6)
  vpg_employees vpg_employees @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vpg_employee_documents_employees_16")

  @@index([employee_id], map: "idx_vpg_employee_documents_employee_id")
}

model vpg_employee_labor_event {
  id               Int              @id @default(autoincrement())
  employee_id      Int
  labor_event_id   Int
  start_date       DateTime         @db.Date
  end_date         DateTime?        @db.Date
  status           String           @db.VarChar(20)
  version          Int              @default(1)
  vpg_employees    vpg_employees    @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vpg_employee_labor_event_employees_17")
  vpg_labor_events vpg_labor_events @relation(fields: [labor_event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vpg_employee_labor_event_labor_events_18")

  @@index([employee_id], map: "idx_vpg_employee_labor_event_employee_id")
  @@index([labor_event_id], map: "idx_vpg_employee_labor_event_labor_event_id")
}

model vpg_employees {
  id                       Int                        @id @default(autoincrement())
  first_name               String                     @db.VarChar(50)
  last_name                String                     @db.VarChar(50)
  middle_name              String                     @db.VarChar(50)
  national_id              String                     @db.VarChar(30)
  email                    String                     @db.VarChar(100)
  position_id              Int
  hire_date                DateTime                   @db.Date
  status                   String                     @db.Char(1)
  version                  Int                        @default(1)
  vpg_bonuses              vpg_bonuses[]
  vpg_branch_employee      vpg_branch_employee[]
  vpg_clock_logs           vpg_clock_logs[]
  vpg_employee_deduction   vpg_employee_deduction[]
  vpg_employee_documents   vpg_employee_documents[]
  vpg_employee_labor_event vpg_employee_labor_event[]
  vpg_payroll_employee     vpg_payroll_employee[]
  vpg_positions            vpg_positions              @relation(fields: [position_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_employees_positions_05")

  @@index([position_id], map: "idx_vpg_employees_position_id")
}

model vpg_enterprise {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @db.VarChar(50)
  image                 Bytes
  creation_date         DateTime                @db.Date
  version               Int                     @default(1)
  vpg_enterprise_branch vpg_enterprise_branch[]
}

model vpg_enterprise_branch {
  enterprise_id  Int
  branch_id      Int
  vpg_branches   vpg_branches   @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_enterprise_branch_branches_02")
  vpg_enterprise vpg_enterprise @relation(fields: [enterprise_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_enterprise_branch_enterprise_01")

  @@id([enterprise_id, branch_id])
  @@index([branch_id], map: "idx_vpg_enterprise_branch_branch_id")
  @@index([enterprise_id], map: "idx_vpg_enterprise_branch_enterprise_id")
}

model vpg_labor_events {
  id                       Int                        @id @default(autoincrement())
  name                     String                     @db.VarChar(100)
  description              String
  version                  Int                        @default(1)
  vpg_employee_labor_event vpg_employee_labor_event[]
}

model vpg_mail_server_settings {
  id           Int     @id @default(autoincrement())
  host         String  @db.VarChar(100)
  port         Int
  username     String  @db.VarChar(100)
  password     String  @db.VarChar(255)
  from_address String  @db.VarChar(100)
  use_ssl      Boolean
  use_tls      Boolean
  version      Int     @default(1)
}

model vpg_payroll_employee {
  payroll_id       Int           @default(autoincrement())
  employee_id      Int
  gross_salary     Decimal       @db.Decimal(10, 2)
  total_deductions Decimal       @db.Decimal(10, 2)
  net_salary       Decimal       @db.Decimal(10, 2)
  version          Int           @default(1)
  vpg_employees    vpg_employees @relation(fields: [employee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_vpg_payroll_employee_employees_08")
  vpg_payrolls     vpg_payrolls  @relation(fields: [payroll_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_payroll_employee_payrolls_07")

  @@id([payroll_id, employee_id])
  @@index([employee_id], map: "idx_vpg_payroll_employee_employee_id")
  @@index([payroll_id], map: "idx_vpg_payroll_employee_payroll_id")
}

model vpg_payroll_types {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(50)
  description  String
  version      Int            @default(1)
  vpg_payrolls vpg_payrolls[]
}

model vpg_payrolls {
  id                   Int                    @id @default(autoincrement())
  payroll_type_id      Int
  period_start         DateTime               @db.Date
  period_end           DateTime               @db.Date
  payment_date         DateTime               @db.Date
  status               String                 @db.VarChar(20)
  version              Int                    @default(1)
  vpg_payroll_employee vpg_payroll_employee[]
  vpg_payroll_types    vpg_payroll_types      @relation(fields: [payroll_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_payrolls_payroll_types_06")

  @@index([payroll_type_id], map: "idx_vpg_payrolls_payroll_type_id")
}

model vpg_positions {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(50)
  description   String
  base_salary   Decimal         @db.Decimal(10, 2)
  version       Int             @default(1)
  vpg_employees vpg_employees[]
}

model vpg_report_logs {
  id                  Int                   @id @default(autoincrement())
  report_type         String                @db.VarChar(50)
  generated_by        Int
  generated_at        DateTime              @db.Timestamp(6)
  period_start        DateTime              @db.Date
  period_end          DateTime              @db.Date
  file_path           String                @db.VarChar(255)
  status              String                @db.VarChar(20)
  version             Int                   @default(1)
  vpg_users           vpg_users             @relation(fields: [generated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_report_logs_users_12")
  vpg_report_versions vpg_report_versions[]

  @@index([generated_by], map: "idx_vpg_report_logs_generated_by")
}

model vpg_report_targets {
  id            Int    @id @default(autoincrement())
  institution   String @db.VarChar(100)
  endpoint_url  String @db.VarChar(255)
  auth_token    String @db.VarChar(255)
  contact_email String @db.VarChar(100)
  version       Int    @default(1)
}

model vpg_report_versions {
  id              Int             @id @default(autoincrement())
  report_log_id   Int
  created_at      DateTime        @db.Timestamp(6)
  file_path       String          @db.VarChar(255)
  remarks         String?
  vpg_report_logs vpg_report_logs @relation(fields: [report_log_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_vpg_report_versions_report_logs_13")

  @@index([report_log_id], map: "idx_vpg_report_versions_report_log_id")
}

model vpg_users {
  id              Int               @id @default(autoincrement())
  first_name      String            @db.VarChar(50)
  last_name       String            @db.VarChar(50)
  middle_name     String            @db.VarChar(50)
  national_id     String            @db.VarChar(30)
  email           String            @db.VarChar(100)
  username        String            @db.VarChar(50)
  password        String            @db.VarChar(255)
  role            String            @db.VarChar(20)
  version         Int               @default(1)
  vpg_audit_logs  vpg_audit_logs[]
  vpg_report_logs vpg_report_logs[]
}
